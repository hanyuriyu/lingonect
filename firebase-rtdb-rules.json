{
  "rules": {
    "presence": {
      "$uid": {
        ".read": true,
        ".write": "$uid === auth.uid"
      }
    },
    "invites": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "auth !== null"
      }
    },
    "activeChats": {
      ".read": true,
      "$uid": {
        ".write": "$uid === auth.uid"
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
