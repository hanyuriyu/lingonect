rules_version = '2';

// Firestore security rules for Lingonect.
//
// These enforce the authorization boundaries the browser UI only *pretends*
// to enforce. Client-side checks for the admin email or a subscription level
// are UI conveniences; the real boundaries live here, because any user can
// call Firestore directly with their own Firebase session.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // The single admin account, identified by its verified email. A more
    // robust approach is a custom claim (request.auth.token.admin == true)
    // set by a trusted backend; email is used here to match the existing app.
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'linguisticsconsulting@gmail.com'
        && request.auth.token.email_verified == true;
    }

    // Incoming value of a field, or null when the field is absent.
    function newVal(field) {
      return field in request.resource.data ? request.resource.data[field] : null;
    }

    // Existing value of a field, or null when absent / on create.
    function oldVal(field) {
      return (resource != null && field in resource.data) ? resource.data[field] : null;
    }

    // True when a non-privileged writer leaves a field exactly as it was.
    function unchanged(field) {
      return newVal(field) == oldVal(field);
    }

    // ---- profiles ----
    // Any signed-in user can read the profile directory (chat user list,
    // admin console, ratings surfaces). Owners may write their own profile
    // but may not grant themselves certification or a paid plan.
    match /profiles/{uid} {
      allow read: if isSignedIn();

      // Admin may write any profile (e.g. set certification for a user).
      allow write: if isAdmin();

      allow create, update: if isSignedIn()
        && request.auth.uid == uid
        // certification stays at its current value, or 'Uncertified' on first save
        && newVal('certification') == (oldVal('certification') == null ? 'Uncertified' : oldVal('certification'))
        // subscription state is set out-of-band (payment webhook / admin) only
        && unchanged('plan')
        && unchanged('subscribed')
        // a stored email may only ever be the writer's own auth email
        && (newVal('email') == null || newVal('email') == request.auth.token.email);

      allow delete: if isAdmin();
    }

    // ---- usernames (lowercased username -> { uid } index) ----
    // A username may only point at your own uid, so nobody can hijack or
    // squat another account's name. Admin may assign on a user's behalf.
    match /usernames/{name} {
      allow read: if isSignedIn();

      allow create: if isAdmin()
        || (isSignedIn() && request.resource.data.uid == request.auth.uid);

      allow update: if isAdmin()
        || (isSignedIn()
            && resource.data.uid == request.auth.uid
            && request.resource.data.uid == request.auth.uid);

      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    // ---- ratings (anonymous engine ratings) ----
    // Any signed-in user may submit and read aggregate ratings. Submitted
    // ratings are immutable from the client.
    match /ratings/{ratingId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.targetLanguage is string
        && request.resource.data.ratings is map
        && (!('sourceText' in request.resource.data)
            || (request.resource.data.sourceText is string
                && request.resource.data.sourceText.size() <= 200));

      allow update, delete: if isAdmin();
    }

    // ---- chat messages (1:1 rooms keyed "<uidA>_<uidB>", alphabetical) ----
    // Only the two participants encoded in the room id may read or post, and a
    // message's `from` must be the sender. Participants may delete (the client
    // purges messages older than 24h); messages are never edited.
    match /chats/{roomId}/messages/{messageId} {
      function isParticipant() {
        return isSignedIn() && request.auth.uid in roomId.split('_');
      }

      allow read: if isParticipant();

      allow create: if isParticipant()
        && request.resource.data.from == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 5000;

      allow delete: if isParticipant();
      allow update: if false;
    }

    // ---- flashcards (owner-scoped) ----
    // A user only ever touches their own stacks. Non-admins are capped at the
    // five fixed slot ids; admin may use auto-generated ids (unlimited stacks).
    match /flashcards/{uid}/stacks/{stackId} {
      allow read: if isSignedIn() && request.auth.uid == uid;

      allow write: if isSignedIn()
        && request.auth.uid == uid
        && (isAdmin() || stackId in ['s1', 's2', 's3', 's4']);
    }

    // Everything not matched above is denied by default.
  }
}
